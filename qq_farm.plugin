#!name=QQ农场抓取CODE
#!desc=自动抓取 QQ 农场 Code 并保存到本地持久化数据中。
#!author=Gemini_Assistant

[Script]
http-request ^https?:\/\/gate-obt\.nqf\.qq\.com script-path=https://raw.githubusercontent.com/story-x/QQ-Farm-Scripts/main/qq_farm_code.js, requires-body=true, tag=抓取QQ农场Code

[Mitm]
hostname = gate-obt.nqf.qq.com
